# HeartCycle CAD System 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=HeartCycle CAD System
APP_VERSION=1.0.0
DEBUG=false
# 重要：生产环境必须修改为强随机字符串
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string

# ==================== 数据库配置 ====================
# SQLite (默认，适合开发和小规模部署)
DATABASE_URL=sqlite:///./data/heartcycle.db

# MySQL (可选，适合生产环境)
# DATABASE_URL=mysql+pymysql://heartcycle:your-password@localhost:3306/heartcycle_cad
# MYSQL_ROOT_PASSWORD=your-mysql-root-password
# MYSQL_PASSWORD=your-mysql-password

# ==================== API 配置 ====================
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8080","http://localhost:5173"]

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== 性能配置 ====================
MAX_UPLOAD_SIZE=104857600
REQUEST_TIMEOUT=300

# ==================== 模型配置 ====================
DEFAULT_MODEL_TYPE=rf
DEFAULT_CV_FOLDS=5
DEFAULT_RANDOM_STATE=42

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_TTL=3600

# ==================== Redis 配置 (可选) ====================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
